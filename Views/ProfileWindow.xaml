<Window x:Class="Computer_networks.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Профиль пользователя"
        Height="580" Width="520"
        MinWidth="460" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Стиль полей ввода -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль полей пароля -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль метки -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Основная кнопка -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005FA3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004A80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem стиль -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#007ACC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Главный Border — стиль как у всех окон проекта -->
    <Border CornerRadius="20"
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Шапка (перетаскивание) ── -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="#007ACC"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    CornerRadius="18,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="AvatarEmoji"
                                   FontSize="22" Foreground="White"
                                   Margin="0,0,10,0" VerticalAlignment="Center"
                                   Text="👤"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderUsername"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="White" Text="Пользователь"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="HeaderRole"
                                           FontSize="11" Foreground="#CCE8FF"
                                           Text="Роль"/>
                                <TextBlock Text=" · " FontSize="11" Foreground="#CCE8FF"/>
                                <TextBlock x:Name="HeaderEmail"
                                           FontSize="11" Foreground="#CCE8FF"
                                           Text="email@example.com"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="18" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="50"
                            VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- ── Статус-сообщение ── -->
            <Border x:Name="StatusBanner" Grid.Row="1"
                    Padding="16,7" Visibility="Collapsed">
                <TextBlock x:Name="StatusText" FontSize="13"
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </Border>

            <!-- ── Вкладки ── -->
            <TabControl Grid.Row="2" Margin="0" BorderThickness="0"
                        Background="Transparent" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Margin" Value="16,6,0,0"/>
                    </Style>
                </TabControl.Resources>

                <!-- ──────── Вкладка 1: Профиль ──────── -->
                <TabItem Header="👤 Профиль">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,20,24,20">
                            <!-- Аватар -->
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Аватар"/>
                            <WrapPanel Margin="0,0,0,16">
                                <RadioButton x:Name="AvatarAdmin"   Content="👑" Tag="👑"  FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                                <RadioButton x:Name="AvatarTeacher" Content="📚" Tag="📚" FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                                <RadioButton x:Name="AvatarStudent" Content="🎓" Tag="🎓" FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                                <RadioButton x:Name="AvatarCode"    Content="💻" Tag="💻" FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                                <RadioButton x:Name="AvatarStar"    Content="⭐" Tag="⭐" FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                                <RadioButton x:Name="AvatarRobot"   Content="🤖" Tag="🤖" FontSize="22" Margin="0,0,10,0" Checked="Avatar_Checked" GroupName="AvatarGroup"/>
                            </WrapPanel>

                            <!-- Имя пользователя -->
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Имя пользователя"/>
                            <TextBox x:Name="UsernameBox" Style="{StaticResource InputStyle}" Margin="0,0,0,14"/>

                            <!-- Email -->
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Email"/>
                            <TextBox x:Name="EmailBox" Style="{StaticResource InputStyle}" Margin="0,0,0,20"/>

                            <!-- Кнопка сохранения -->
                            <Button x:Name="SaveProfileButton"
                                    Content="💾 Сохранить профиль"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"
                                    Click="SaveProfile_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ──────── Вкладка 2: Пароль ──────── -->
                <TabItem Header="🔐 Пароль">
                    <StackPanel Margin="24,20,24,20">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Текущий пароль"/>
                        <PasswordBox x:Name="OldPasswordBox" Style="{StaticResource PasswordStyle}" Margin="0,0,0,14"/>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Новый пароль"/>
                        <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource PasswordStyle}" Margin="0,0,0,14"/>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Повторите новый пароль"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PasswordStyle}" Margin="0,0,0,8"/>

                        <!-- Требования к паролю -->
                        <Border Background="#F0F7FF" CornerRadius="6" Padding="12,8" Margin="0,0,0,20">
                            <TextBlock Text="Минимум 6 символов. Рекомендуется использовать буквы, цифры и символы."
                                       FontSize="11" Foreground="#555" TextWrapping="Wrap"/>
                        </Border>

                        <Button x:Name="ChangePasswordButton"
                                Content="🔑 Изменить пароль"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Click="ChangePassword_Click"/>
                    </StackPanel>
                </TabItem>

                <!-- ──────── Вкладка 3: Мои группы (только Преподаватель) ──────── -->
                <TabItem x:Name="GroupsTabItem" Header="👥 Мои группы">
                    <Grid Margin="24,16,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок меняется под роль -->
                        <TextBlock x:Name="GroupsHeaderText"
                                   Grid.Row="0"
                                   Text="Мои группы"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,10"/>

                        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                            <ListView x:Name="GroupsListView"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      SelectionChanged="GroupsListView_SelectionChanged">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="ItemBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="#F0F0F0"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="14,10">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F5F9FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EBF5FF"/>
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#B3D9FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Цветной маркер слева -->
                                            <Border Grid.Column="0"
                                                    Width="4" CornerRadius="2"
                                                    Background="#007ACC"
                                                    Margin="0,0,12,0"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding GroupName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#2C3E50"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="📖 " FontSize="11"/>
                                                    <TextBlock Text="{Binding CourseName, TargetNullValue='Курс не назначен'}"
                                                               FontSize="11" Foreground="#888"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Бейдж со студентами (только для преподавателя) -->
                                            <Border x:Name="StudentCountBadge"
                                                    Grid.Column="2"
                                                    Background="#EBF5FF" CornerRadius="10"
                                                    Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" Foreground="#007ACC" FontWeight="SemiBold">
                                                    <Run Text="{Binding StudentCount, Mode=OneWay}"/>
                                                    <Run Text=" студ."/>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!-- Пустое состояние -->
                        <TextBlock x:Name="NoGroupsText"
                                   Grid.Row="1"
                                   Text="📭 У вас пока нет прикреплённых групп."
                                   FontSize="13" Foreground="#999"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <!-- Нижняя панель: подсказка + кнопка статистики для препода -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="GroupsFooterText"
                                       Grid.Column="0"
                                       FontSize="11" Foreground="#AAA"
                                       VerticalAlignment="Center"
                                       Text="Для управления группами перейдите в Администрирование → Группы"/>
                            <Button x:Name="ViewGroupStatsButton"
                                    Grid.Column="1"
                                    Content="📊 Статистика группы"
                                    Visibility="Collapsed"
                                    IsEnabled="False"
                                    Click="ViewGroupStatsButton_Click"
                                    Background="#007ACC"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="14,7"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#007ACC"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#005C99"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>

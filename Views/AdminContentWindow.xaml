<Window x:Class="Computer_networks.Views.AdminContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="📚 Редактор учебного контента" 
        Height="971" 
        Width="1469" 
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Icon="/images/i (3).ico"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Стиль для кнопок (как в Leaderboard) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для маленьких кнопок -->
        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Стиль для заголовка -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
        </Style>

        <!-- Стиль для подзаголовка -->
        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль для TreeViewItem -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для ComboBox (как в Leaderboard) -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для GridSplitter -->
        <Style x:Key="GridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>

        <!-- Стиль для Border с тенью -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Главный Border с закруглением и тенью (как в Leaderboard) -->
    <Border CornerRadius="20" 
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна (перетаскивание) -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    MouseLeftButtonDown="DragWindow"
                    CornerRadius="18,18,0,0"
                    Margin="-20,-20,-20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="25,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="📚" 
                                   FontSize="24" 
                                   Foreground="White" 
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="РЕДАКТОР КОНТЕНТА" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="50"
                            Height="50"
                            ToolTip="Закрыть (Esc)"/>
                </Grid>
            </Border>

            <!-- Заголовок и выбор курса -->
            <Grid Grid.Row="1" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="📚 Редактор учебного контента"
                           Style="{StaticResource HeaderTextStyle}"/>

                <!-- Выбор курса -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock Text="Курс:" 
                               Style="{StaticResource SubHeaderTextStyle}"
                               Margin="0,0,10,0"/>
                    <ComboBox x:Name="CourseSelector"
                              Style="{StaticResource ComboBoxStyle}"
                              Width="200"
                              DisplayMemberPath="CourseName"
                              SelectedValuePath="CourseID"
                              SelectionChanged="CourseSelector_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Основной контент -->
            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Колонка 1: Структура тем -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="📂 Структура тем" 
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    Margin="0,0,0,10">
                            <Button x:Name="AddRootTopicButton" 
                                    Content="➕ Главная тема"
                                    Style="{StaticResource SmallButtonStyle}"
                                    Background="#2196F3"
                                    Margin="0,0,10,0"
                                    Click="AddRootTopicButton_Click"/>
                            <Button x:Name="AddSubTopicButton" 
                                    Content="📁 Подтема"
                                    Style="{StaticResource SmallButtonStyle}"
                                    Background="#FF9800"
                                    Click="AddSubTopicButton_Click"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" 
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TreeView x:Name="TopicsTreeView"
                                      SelectedItemChanged="TopicsTreeView_SelectedItemChanged"
                                      BorderThickness="0" 
                                      Background="Transparent">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📄" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Title}" 
                                                       TextWrapping="Wrap"
                                                       FontSize="13"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Style="{StaticResource GridSplitterStyle}"/>

                <!-- Колонка 2: Редактор -->
                <ScrollViewer Grid.Column="2" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Border Style="{StaticResource CardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="📝 Тип содержимого" 
                                           Style="{StaticResource SectionHeaderStyle}"/>
                                <ComboBox x:Name="ContentTypeComboBox" 
                                          Style="{StaticResource ComboBoxStyle}"
                                          SelectionChanged="ContentTypeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="📄 Текстовая страница"/>
                                    <ComboBoxItem Content="🔗 Раздел (только заголовок)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                <TextBlock Text="✏️ Заголовок темы" 
                                           Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBox x:Name="TitleTextBox" 
                                         Height="40"
                                         TextChanged="TitleTextBox_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" x:Name="ContentPanel" Margin="0,0,0,15">
                                <TextBlock Text="📝 Содержание" 
               Style="{StaticResource SectionHeaderStyle}"/>

                                <!-- Обычный TextBox без форматирования -->
                                <TextBox x:Name="ContentTextBox" 
             TextWrapping="Wrap" 
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             MinHeight="300"
             TextChanged="ContentTextBox_TextChanged"/>
                            </StackPanel>

                            <!-- ═══════════════════════════════════════════════════ -->
                            <!-- СЕКЦИЯ ВЛОЖЕНИЙ (Grid.Row="3") -->
                            <!-- ═══════════════════════════════════════════════════ -->
                            <Border Grid.Row="3" 
        Background="#F8F9FA" 
        CornerRadius="6" 
        BorderBrush="#E0E0E0" 
        BorderThickness="1"
        Padding="12" 
        Margin="0,0,0,15">
                                <StackPanel>
                                    <!-- Заголовок секции с кнопкой -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="📎 Прикреплённые файлы" 
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0"/>

                                        <Button Grid.Column="1"
                    x:Name="BtnAddAttachment"
                    Content="➕ Прикрепить файл"
                    Click="AddAttachment_Click"
                    Background="#28A745" 
                    Foreground="White"
                    Padding="10,5"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Список файлов -->
                                    <ItemsControl x:Name="AttachmentsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" 
                            CornerRadius="5"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Padding="10,8" 
                            Margin="0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Иконка типа файла -->
                                                        <TextBlock Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="22"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>

                                                        <!-- Имя и размер -->
                                                        <StackPanel Grid.Column="1" 
                                        VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FileName}"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                                                            <TextBlock Text="{Binding SizeText}"
                                           FontSize="11"
                                           Foreground="#888"/>
                                                        </StackPanel>

                                                        <!-- Кнопка открыть -->
                                                        <Button Grid.Column="2"
                                    Content="📂 Открыть"
                                    Tag="{Binding}"
                                    Click="OpenAttachment_Click"
                                    Background="#007ACC"
                                    Foreground="White"
                                    Padding="10,5"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Margin="5,0"
                                    Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- Кнопка удалить -->
                                                        <Button Grid.Column="3"
                                    Content="🗑️"
                                    Tag="{Binding AttachmentID}"
                                    Click="DeleteAttachment_Click"
                                    Background="#DC3545"
                                    Foreground="White"
                                    Width="32" Height="32"
                                    FontSize="13"
                                    Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="2">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Пустое состояние -->
                                    <TextBlock x:Name="NoAttachmentsText"
                   Text="Нет прикреплённых файлов"
                   FontSize="12"
                   Foreground="#AAA"
                   HorizontalAlignment="Center"
                   Margin="0,5"/>
                                </StackPanel>
                            </Border>

                            <!-- ═══════════════════════════════════════════════════ -->
                            <!-- СЕКЦИЯ ССЫЛОК (Grid.Row="4") -->
                            <!-- ═══════════════════════════════════════════════════ -->
                            <Border Grid.Row="4"
        Background="#F0F7FF"
        CornerRadius="6"
        BorderBrush="#CCE0FF"
        BorderThickness="1"
        Padding="12"
        Margin="0,0,0,15">
                                <StackPanel>
                                    <!-- Заголовок секции с кнопкой -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="🔗 Полезные ссылки"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0"/>

                                        <Button Grid.Column="1"
                    x:Name="BtnAddLink"
                    Content="➕ Добавить ссылку"
                    Click="AddLink_Click"
                    Background="#17A2B8"
                    Foreground="White"
                    Padding="10,5"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Список ссылок -->
                                    <ItemsControl x:Name="LinksList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White"
                            CornerRadius="5"
                            BorderBrush="#CCE0FF"
                            BorderThickness="1"
                            Padding="10,8"
                            Margin="0,3"
                            Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                          Command="{x:Null}"/>
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#007ACC"/>
                                                            <TextBlock Text="{Binding Domain}"
                                           FontSize="11"
                                           Foreground="#888"/>
                                                            <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Foreground="#555"
                                           TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <!-- Кнопка открыть в браузере -->
                                                        <Button Grid.Column="1"
                                    Content="🌐 Открыть"
                                    Tag="{Binding URL}"
                                    Click="OpenLink_Click"
                                    Background="#007ACC"
                                    Foreground="White"
                                    Padding="10,5"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Margin="5,0"
                                    Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- Кнопка удалить -->
                                                        <Button Grid.Column="2"
                                    Content="🗑️"
                                    Tag="{Binding LinkID}"
                                    Click="DeleteLink_Click"
                                    Background="#DC3545"
                                    Foreground="White"
                                    Width="32" Height="32"
                                    FontSize="13"
                                    Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="2">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Пустое состояние -->
                                    <TextBlock x:Name="NoLinksText"
                   Text="Нет добавленных ссылок"
                   FontSize="12"
                   Foreground="#AAA"
                   HorizontalAlignment="Center"
                   Margin="0,5"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="5" 
                                       x:Name="StatusText" 
                                       Text="Выберите тему для редактирования"
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       Margin="0,10,0,0"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Grid>

            <!-- Нижняя панель -->
            <Border Grid.Row="3" 
                    Background="#F0F0F0"
                    CornerRadius="0,0,18,18"
                    Margin="-20,-20,-20,-20"
                    Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SaveTopicButton" 
                            Content="💾 Сохранить (Ctrl+S)"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#33AA33"
                            Width="188"
                            Margin="0,0,10,0"
                            Click="SaveTopicButton_Click" Height="43"/>

                    <Button x:Name="DeleteTopicButton" 
                            Content="🗑️ Удалить (Del)"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#CC0000"
                            Width="170"
                            Click="DeleteTopicButton_Click" Height="41"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
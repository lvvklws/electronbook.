<Window x:Class="Computer_networks.Views.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заметка" 
        Height="450" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        Icon="/images/i (3).ico"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Главный Border с закруглением и тенью -->
    <Border CornerRadius="15" 
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна (для перетаскивания) -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    MouseLeftButtonDown="DragWindow"
                    CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="📝" 
                                   FontSize="20" 
                                   Foreground="White" 
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TopicTitleText" 
                                   Text="Заметка к теме"
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="50"
                            Height="50"/>
                </Grid>
            </Border>

            <!-- Поле для ввода заметки -->
            <Border Grid.Row="1" 
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1"
                    Padding="20"
                    CornerRadius="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="NoteTextBox" 
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="14"
                             Padding="10"
                             Foreground="#333333"
                             MinHeight="200"/>
                </ScrollViewer>
            </Border>

            <!-- Панель кнопок -->
            <Border Grid.Row="2" 
                    Background="#F0F0F0"
                    CornerRadius="0,0,13,13"
                    Padding="20">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Сохранить" 
                            Click="SaveButton_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#28A745" 
                            Width="160"
                            Margin="0,0,10,0"/>
                    <Button Content="Отмена" 
                            Click="CancelButton_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#6C757D" 
                            Width="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
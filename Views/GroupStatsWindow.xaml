<Window x:Class="Computer_networks.Views.GroupStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика группы" 
        Height="750" 
        Width="900"
        WindowStartupLocation="CenterOwner" 
        Background="Transparent"
        WindowStyle="None" 
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" 
            Background="White" 
            BorderBrush="#007ACC" 
            BorderThickness="2" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    CornerRadius="10,10,0,0" 
                    Padding="15"
                    MouseLeftButtonDown="DragWindow">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊 Статистика группы: " 
                                   FontSize="18" Foreground="White"/>
                        <TextBlock x:Name="GroupNameText" 
                                   Text="Загрузка..."
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <Button Content="✕" 
                            Width="30" Height="30"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="16" FontWeight="Bold"
                            HorizontalAlignment="Right" Cursor="Hand"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,15">
                <StackPanel>

                    <!-- Карточки сводки -->
                    <WrapPanel Margin="0,0,0,15">
                        <Border Style="{StaticResource StatCardStyle}" Width="195">
                            <StackPanel>
                                <TextBlock Text="Средний балл" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock x:Name="TxtAvgScore" Text="—" Style="{StaticResource StatNumberStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Width="195">
                            <StackPanel>
                                <TextBlock Text="Всего попыток" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock x:Name="TxtTotalAttempts" Text="—" Style="{StaticResource StatNumberStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Width="195">
                            <StackPanel>
                                <TextBlock Text="Изучено тем" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock x:Name="TxtCompletedTopics" Text="—" Style="{StaticResource StatNumberStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Width="195">
                            <StackPanel>
                                <TextBlock Text="Тестов на 100%" Style="{StaticResource StatLabelStyle}"/>
                                <TextBlock x:Name="TxtPerfectTests" Text="—" Style="{StaticResource StatNumberStyle}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- Успеваемость по темам -->
                    <!-- ИСПРАВЛЕНО: был MultiBinding с ActualWidth — он возвращал 0 при первом рендере.
                         Заменён на стандартный ProgressBar: Value="GroupAvgScore" Maximum="100". -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📈 Успеваемость по темам" 
                                       FontSize="16" FontWeight="Bold" 
                                       Foreground="#007ACC" Margin="0,0,0,15"/>

                            <ItemsControl x:Name="TopicsStatsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="55"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TopicTitle}"
                                                       FontSize="12" Foreground="#555"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>

                                            <!-- Стандартный ProgressBar — не зависит от ActualWidth -->
                                            <ProgressBar Grid.Column="1"
                                                         Value="{Binding GroupAvgScore}"
                                                         Maximum="100"
                                                         Height="18"
                                                         Foreground="#007ACC"
                                                         Background="#E8E8E8"
                                                         BorderThickness="0"
                                                         VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding GroupAvgScore, StringFormat={}{0:F1}%}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="#007ACC"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Сравнение с общим средним -->
                    <!-- ИСПРАВЛЕНО: добавлена колонка DiffText (+X% / -X%) для наглядности.
                         CompareColor теперь вычисляется в code-behind через TopicComparisonRow. -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📊 Сравнение с общим средним" 
                                       FontSize="16" FontWeight="Bold" 
                                       Foreground="#007ACC" Margin="0,0,0,15"/>

                            <ItemsControl x:Name="ComparisonList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TopicTitle}"
                                                       FontSize="12" Foreground="#555"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>

                                            <ProgressBar Grid.Column="1"
                                                         Value="{Binding GroupAvgScore}"
                                                         Maximum="100"
                                                         Height="18"
                                                         Foreground="{Binding CompareColor}"
                                                         Background="#E8E8E8"
                                                         BorderThickness="0"
                                                         VerticalAlignment="Center"/>

                                            <!-- группа% (общий%) +/-дельта -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding GroupAvgScore, StringFormat={}{0:F0}%}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#007ACC"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DiffText}"
                                                           FontSize="11"
                                                           Foreground="{Binding CompareColor}"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Лучшие студенты группы -->
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="🏆 Лучшие студенты группы" 
                                       FontSize="16" FontWeight="Bold" 
                                       Foreground="#007ACC" Margin="0,0,0,15"/>

                            <DataGrid x:Name="TopStudentsGrid" 
                                      AutoGenerateColumns="False" 
                                      MaxHeight="220"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FAFBFC"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Студент" 
                                                        Binding="{Binding Username}" 
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Средний балл" 
                                                        Binding="{Binding AvgScore, StringFormat={}{0:F1}%}" 
                                                        Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#007ACC"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Попыток" 
                                                        Binding="{Binding TotalAttempts}" 
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Нижняя панель: время обновления + кнопки -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5" 
                    CornerRadius="0,0,10,10" 
                    Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="UpdateTimeText"
                               Text=""
                               Foreground="#999" FontSize="11"
                               VerticalAlignment="Center"/>

                    <!-- Кнопка обновить (F5) -->
                    <Button
                            Content="🔄 Обновить"
                            Click="RefreshButton_Click"
                            Background="#007ACC"
                            Foreground="White"
                            Padding="20,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Margin="557,0,10,-2"
                            ToolTip="Обновить статистику (F5)" Grid.ColumnSpan="2"/>

                    <Button Grid.Column="2"
                            Content="✕ Закрыть"
                            Click="CloseButton_Click"
                            Background="#6C757D"
                            Foreground="White"
                            Padding="20,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

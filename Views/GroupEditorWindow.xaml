<Window x:Class="Computer_networks.Views.GroupEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Computer_networks.Views"
        mc:Ignorable="d"
        Title="Редактор групп" 
        Height="697" 
        Width="808"
        WindowStartupLocation="CenterOwner" 
        Background="Transparent"
        WindowStyle="None" 
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="DialogButtonStyle">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" 
            Background="White" 
            BorderBrush="#007ACC" 
            BorderThickness="2" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    CornerRadius="10,10,0,0" 
                    Padding="15"
                    MouseLeftButtonDown="DragWindow">
                <Grid>
                    <TextBlock x:Name="WindowTitleText" 
                               Text="📁 Создание новой группы" 
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" 
                            Width="30" Height="30"
                            Background="Transparent" 
                            Foreground="White"
                            BorderThickness="0" 
                            FontSize="16" FontWeight="Bold"
                            HorizontalAlignment="Right" 
                            Cursor="Hand"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,15">
                <StackPanel>
                    <!-- Название группы -->
                    <TextBlock Text="Название группы *" 
                               FontWeight="SemiBold" 
                               Foreground="#333"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="GroupNameBox" 
                             TextChanged="GroupNameBox_TextChanged"
                             ToolTip="Например: ИС-21, ПИ-22, 2 курс"/>

                    <!-- Описание -->
                    <TextBlock Text="Описание / Год" 
                               FontWeight="SemiBold" 
                               Foreground="#333"
                               Margin="0,15,0,5"/>
                    <TextBox x:Name="GroupDescBox" 
                             ToolTip="Например: 2 курс 2024, группа вечерников"/>

                    <!-- Выбор курса -->
                    <TextBlock Text="Назначить курс" 
                               FontWeight="SemiBold" 
                               Foreground="#333"
                               Margin="0,15,0,5"/>


                    <ComboBox x:Name="CourseCombo" 
          Grid.Row="1" 
          Margin="0,5,0,15"
          DisplayMemberPath="CourseName" 
          SelectedValuePath="CourseID"
          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#EEE" Margin="0,20,0,15"/>

                    <!-- Выбор студентов -->
                    <TextBlock Text="Добавить студентов в группу" 
                               FontWeight="Bold" 
                               Foreground="#007ACC"
                               FontSize="14"
                               Margin="0,0,0,10"/>

                    <!-- Поиск студентов -->
                    <TextBox x:Name="SearchStudentBox" 
                             TextChanged="SearchStudentBox_TextChanged"
                             Margin="0,0,0,10">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White"
                                                    BorderBrush="#DDD"
                                                    BorderThickness="1"
                                                    CornerRadius="5">
                                                <Grid>
                                                    <TextBlock Text="🔍 Поиск студентов по имени или email..."
                                                               FontSize="12" Foreground="#AAA"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Кнопки управления выбором -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Выберите студентов для добавления"
                                   FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="✅ Выбрать всех" 
                                    Click="SelectAll_Click"
                                    Background="#28A745" 
                                    Foreground="White"
                                    Padding="10,5" 
                                    FontSize="11"
                                    Margin="0,0,5,0"
                                    Cursor="Hand"/>
                            <Button Content="🔲 Снять все" 
                                    Click="DeselectAll_Click"
                                    Background="#6C757D" 
                                    Foreground="White"
                                    Padding="10,5" 
                                    FontSize="11"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- Список студентов -->
                    <Border BorderBrush="#DDD" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Height="250">
                        <ListBox x:Name="StudentsList" 
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Username}" 
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Email}" 
                                                       FontSize="11" 
                                                       Foreground="#666"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock x:Name="SelectedCountText" 
                               Text="Выбрано: 0 студентов"
                               FontSize="11" 
                               Foreground="#007ACC"
                               Margin="0,5,0,0"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки внизу -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5" 
                    CornerRadius="0,0,10,10" 
                    Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               x:Name="ErrorText" 
                               Text="* обязательные поля"
                               Foreground="#999"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" 
                            x:Name="SaveButton"
                            Content="💾 Сохранить"
                            Click="SaveButton_Click"
                            Background="#28A745"
                            Style="{StaticResource DialogButtonStyle}"
                            Margin="0,0,10,0"
                            IsEnabled="False"/>

                    <Button Grid.Column="2" 
                            Content="✕ Отмена"
                            Click="CancelButton_Click"
                            Background="#6C757D"
                            Style="{StaticResource DialogButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
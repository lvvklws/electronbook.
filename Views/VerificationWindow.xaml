<Window x:Class="Computer_networks.Views.VerificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Подтверждение email"
        Height="445" Width="457"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="CodeDigitBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#F5F9FF"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="CaretBrush" Value="#1565C0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="White"
            Effect="{DynamicResource MaterialDesignShadowDepth3}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="#1565C0" CornerRadius="16,16,0,0"
                    MouseDown="DragWindow" Cursor="SizeAll" Padding="20,14">
                <Grid>
                    <TextBlock Text="Подтверждение email"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton" Content="✕"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="16" Cursor="Hand"
                            Padding="8,4"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <StackPanel Grid.Row="1" Margin="32,24,32,28" VerticalAlignment="Center">

                <TextBlock x:Name="InstructionText"
                           Text="Введи 6-значный код, отправленный на твою почту"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="14" Foreground="#555" Margin="0,0,0,8"/>

                <TextBlock x:Name="EmailLabel"
                           TextAlignment="Center" FontSize="13"
                           Foreground="#1565C0" FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <!-- Поля ввода цифр -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBox x:Name="D1" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag="D2"/>
                    <TextBox x:Name="D2" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag="D3"/>
                    <TextBox x:Name="D3" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag="D4"/>
                    <TextBox x:Name="D4" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag="D5"/>
                    <TextBox x:Name="D5" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag="D6"/>
                    <TextBox x:Name="D6" Style="{StaticResource CodeDigitBox}" PreviewTextInput="Digit_PreviewTextInput" TextChanged="Digit_TextChanged" Tag=""/>
                </StackPanel>

                <!-- Ошибка -->
                <TextBlock x:Name="ErrorText"
                           TextAlignment="Center" Foreground="#D32F2F"
                           FontSize="13" Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <!-- Резервный код (если SMTP недоступен) -->
                <Border x:Name="FallbackCodePanel"
                        Visibility="Collapsed"
                        Background="#FFF8E1"
                        BorderBrush="#F9A825"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="⚠ Письмо не отправлено. Используй этот код:"
                                   FontSize="12" Foreground="#F57F17"
                                   FontWeight="SemiBold" Margin="0,0,0,6"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="FallbackCodeText"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#E65100"
                                   TextAlignment="Center"
                                   FontFamily="Courier New"/>
                    </StackPanel>
                </Border>

                <!-- Кнопка подтвердить -->
                <Button x:Name="ConfirmButton"
                        Content="Подтвердить"
                        Click="ConfirmButton_Click"
                        Height="44" FontSize="15" FontWeight="SemiBold"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Повторная отправка -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                    <TextBlock Text="Не пришёл код? " Foreground="#888" FontSize="13"/>
                    <TextBlock x:Name="ResendLink"
                               Text="Отправить повторно"
                               Foreground="#1565C0" FontSize="13"
                               Cursor="Hand" TextDecorations="Underline"
                               MouseDown="ResendLink_MouseDown"/>
                </StackPanel>

                <TextBlock x:Name="TimerText"
                           TextAlignment="Center" Foreground="#999"
                           FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

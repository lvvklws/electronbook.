<Window x:Class="Computer_networks.Views.LabToolkitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторный IPv4-калькулятор"
        Width="820"
        Height="620"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#007ACC"
                CornerRadius="10"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🧪"
                           FontSize="20"
                           Foreground="White"
                           Margin="0,0,10,0"/>
                <TextBlock Text="Лабораторный IPv4-калькулятор"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,12"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IpInputTextBox"
                         Grid.Column="0"
                         Height="34"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         ToolTip="Введите IPv4 адрес, например: 192.168.10.25"
                         Text="192.168.10.25"/>
                <TextBox x:Name="PrefixInputTextBox"
                         Grid.Column="1"
                         Height="34"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         ToolTip="Префикс CIDR от 0 до 32"
                         Text="24"/>
                <Button Grid.Column="2"
                        Content="Рассчитать"
                        Padding="18,6"
                        Margin="0,0,8,0"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="CalculateButton_Click"/>
                <Button Grid.Column="3"
                        Content="Вариант"
                        Padding="18,6"
                        Background="#F0F7FF"
                        Foreground="#007ACC"
                        BorderBrush="#BFD8F5"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Click="GenerateVariantButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Результаты расчета"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#007ACC"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="NetworkAddressText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="SubnetMaskText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="WildcardMaskText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="BroadcastAddressText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="FirstHostText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="LastHostText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="HostCountText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                    <TextBlock x:Name="AddressClassText"
                               FontSize="14"
                               Margin="0,4,0,4"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="8,0,0,0"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Готовый фрагмент отчета"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#007ACC"
                               Margin="0,0,0,10"/>
                    <TextBox x:Name="ReportTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="8"
                             Background="#F8F9FA"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="#F0F7FF"
                BorderBrush="#BFD8F5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <TextBlock x:Name="StatusText"
                       Text="Подсказка: введите IP и префикс, затем нажмите «Рассчитать». Горячая клавиша для открытия окна — F3."
                       Foreground="#345"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>

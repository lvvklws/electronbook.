<Window x:Class="Computer_networks.Views.AddLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить ссылку"
        Height="343" Width="548"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="12"
            Background="White"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0"
                    Background="#007ACC"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseDown">
                <Grid Margin="15,0">
                    <TextBlock Text="🔗 Добавить внешнюю ссылку"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            Click="Cancel_Click"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="14"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <StackPanel Grid.Row="1" Margin="20,15,20,20">

                <TextBlock Text="Название *"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox"
                         Height="34"
                         Padding="8,6"
                         BorderBrush="#DDD"
                         FontSize="13"
                         Margin="0,0,0,10"
                         ToolTip="Например: Документация Microsoft"/>

                <TextBlock Text="URL *"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="UrlBox"
                         Height="34"
                         Padding="8,6"
                         BorderBrush="#DDD"
                         FontSize="13"
                         Margin="0,0,0,10"
                         ToolTip="https://..."/>

                <TextBlock Text="Описание (необязательно)"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="DescBox"
                         Height="34"
                         Padding="8,6"
                         BorderBrush="#DDD"
                         FontSize="13"
                         Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnSave"
                            Content="💾 Сохранить"
                            Click="Save_Click"
                            Width="120" Height="34"
                            Background="#007ACC"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0099FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Отмена"
                            Click="Cancel_Click"
                            Width="90" Height="34"
                            Background="#6C757D"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5A6268"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>

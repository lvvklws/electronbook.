<Window x:Class="Computer_networks.Views.GlossaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Computer_networks.ViewModels"
        mc:Ignorable="d"
        Title="📚 Словарь терминов" 
        Height="808" 
        Width="1141" 
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Icon="/images/i (3).ico" 
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:GlossaryViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9F9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Главный Border с закруглением и тенью -->
    <Border CornerRadius="20" 
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна (перетаскивание) -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    MouseLeftButtonDown="DragWindow"
                    CornerRadius="18,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="📚" 
                                   FontSize="24" 
                                   Foreground="White" 
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="СЛОВАРЬ ТЕРМИНОВ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="50"
                            Height="50"/>
                </Grid>
            </Border>

            <!-- ПАНЕЛЬ ПОИСКА -->
            <Border Grid.Row="2" 
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="20,10,20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поле поиска -->
                    <TextBox Grid.Column="0" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"
                             Padding="12,10"
                             VerticalContentAlignment="Center"
                             Foreground="#2C3E50"
                             Background="#F8F9F9"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"/>

                    <!-- Счетчик терминов -->
                    <Border Grid.Column="1" 
                            Background="#007ACC"
                            CornerRadius="5"
                            Padding="15,0"
                            Margin="10,0,0,0"
                            Height="40">
                        <StackPanel Orientation="Horizontal" 
                                    VerticalAlignment="Center">
                            <TextBlock Text="📊" 
                                       FontSize="16" 
                                       Foreground="White"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TermsCount}" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="терминов" 
                                       FontSize="12" 
                                       Foreground="#E0E0E0"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- СПИСОК ТЕРМИНОВ -->
            <Border Grid.Row="3" 
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="20,10,20,20"
                    Padding="0">

                <ListView x:Name="GlossaryListView"
                          ItemsSource="{Binding Terms}"
                          SelectedItem="{Binding SelectedTerm}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Термин" Width="250">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" 
                                                    Margin="10,5">
                                            <Border Background="#007ACC"
                                                    Width="24" Height="24"
                                                    CornerRadius="5"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="📌" 
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding Term}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="14"
                                                       Foreground="#2C3E50"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Определение" Width="600">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Definition}" 
                                                   TextWrapping="Wrap" 
                                                   FontSize="13"
                                                   Foreground="#566573"
                                                   Margin="10,5"
                                                   LineHeight="18"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Нижняя панель с кнопками -->
            <!-- Нижняя панель с кнопками -->
            <Border Grid.Row="4" 
        Background="#F0F0F0"
        CornerRadius="0,0,18,18"
        Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Информация о выбранном термине -->
                    <Border Grid.Column="0" 
                Background="White"
                CornerRadius="5"
                Padding="10"
                VerticalAlignment="Center"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Height="40"
                Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📌 Выбрано: " 
                           FontSize="13" 
                           Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding SelectedTerm.Term, FallbackValue='термин не выбран'}" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка копирования -->
                    <Button Grid.Column="1"
                x:Name="CopyTermButton" 
                Content="КОПИРОВАТЬ" 
                Command="{Binding CopyTermCommand}"
                Background="#28A745"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                FontSize="14"
                Padding="20,5"
                Cursor="Hand"
                Margin="0,0,10,0"/>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="2"
                x:Name="CloseButton"
                Content="ЗАКРЫТЬ" 
                Command="{Binding CloseCommand}"
                Background="#6C757D"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                FontSize="14"
                Padding="20,5"
                Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
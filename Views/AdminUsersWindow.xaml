<Window x:Class="Computer_networks.Views.AdminUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Computer_networks.ViewModels"
        xmlns:utilities="clr-namespace:Computer_networks.Utilities"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Управление Пользователями и Прогрессом"
        Height="950"
        Width="1400"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Icon="/images/i (3).ico"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:AdminUsersViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9F9"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Border CornerRadius="20"
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Синяя шапка -->
                <RowDefinition Height="50"/>
                <!-- Строка с заголовком и выбором курса -->
                <RowDefinition Height="Auto"/>
                <!-- Таблица пользователей — 55% свободного места -->
                <RowDefinition Height="0.55*" MinHeight="140"/>
                <!-- Перетаскиваемый разделитель -->
                <RowDefinition Height="5"/>
                <!-- Таблица статистики — 45% свободного места -->
                <RowDefinition Height="0.45*" MinHeight="120"/>
                <!-- Нижняя панель с кнопками -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ ШАПКА ═══ -->
            <Border Grid.Row="0"
                    Background="#007ACC"
                    MouseLeftButtonDown="DragWindow"
                    CornerRadius="18,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="25,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="👥"
                                   FontSize="22"
                                   Foreground="White"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="50"
                            Height="50"
                            ToolTip="Закрыть (Esc)"/>
                </Grid>
            </Border>

            <!-- ═══ ЗАГОЛОВОК + ВЫБОР КУРСА ═══ -->
            <Grid Grid.Row="1" Margin="20,12,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="👥 Пользователи и статистика"
                           Style="{StaticResource HeaderTextStyle}"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Курс:"
                               Style="{StaticResource SubHeaderTextStyle}"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="CourseSelector"
                              Style="{StaticResource ComboBoxStyle}"
                              Width="200"
                              DisplayMemberPath="CourseName"
                              SelectedValuePath="CourseID"
                              SelectionChanged="CourseSelector_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- ═══ СЕКЦИЯ 1: СПИСОК ПОЛЬЗОВАТЕЛЕЙ ═══ -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="20,0,20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.07"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Синяя шапка секции — как в тестировании -->
                    <Border Grid.Row="0"
                            Background="#007ACC"
                            CornerRadius="7,7,0,0"
                            Padding="14,8">
                        <TextBlock Text="📋 Список пользователей"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="UsersDataGrid"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              BorderThickness="0"
                              SelectionChanged="DataGrid_SelectionChanged"
                              CellEditEnding="UsersDataGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding UserID}"
                                                IsReadOnly="True"
                                                Width="60"/>
                            <DataGridTextColumn Header="Логин"
                                                Binding="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                Width="2*"/>

                            <!-- Роль: цветной бейдж + ComboBox при редактировании -->
                            <DataGridTemplateColumn Header="Роль" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RoleBadgeColor}"
                                                CornerRadius="5"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="4,0">
                                            <TextBlock Text="{Binding RoleName}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding RoleID, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  IsEnabled="{Binding DataContext.CanManageUsers,
                                                              RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ComboBoxItem Content="Администратор" Tag="1"/>
                                            <ComboBoxItem Content="Преподаватель"  Tag="2"/>
                                            <ComboBoxItem Content="Студент"        Tag="3"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Дата регистрации"
                                                Binding="{Binding RegistrationDate, StringFormat='dd.MM.yyyy'}"
                                                IsReadOnly="True"
                                                Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ═══ ПЕРЕТАСКИВАЕМЫЙ РАЗДЕЛИТЕЛЬ ═══ -->
            <GridSplitter Grid.Row="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Height="5"
                          Background="#CCCCCC"
                          ResizeDirection="Rows"
                          ShowsPreview="True"
                          Cursor="SizeNS"
                          Margin="20,0"/>

            <!-- ═══ СЕКЦИЯ 2: СТАТИСТИКА ПОЛЬЗОВАТЕЛЯ ═══ -->
            <Border Grid.Row="4"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="20,0,20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.07"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Синяя шапка с именем пользователя -->
                    <Border Grid.Row="0"
                            Background="#007ACC"
                            CornerRadius="7,7,0,0"
                            Padding="14,8">
                        <TextBlock Text="{Binding SelectedUser.Username,
                                           StringFormat='📈 Прогресс и статистика: {0}',
                                           TargetNullValue='📈 Выберите пользователя для просмотра статистики'}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedUser.TestStatistics}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              SelectionChanged="DataGrid_SelectionChanged_1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тема"
                                                Binding="{Binding TopicTitle}"
                                                Width="3*"/>
                            <DataGridTextColumn Header="Попыток"
                                                Binding="{Binding Attempts}"
                                                Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Средний результат"
                                                Binding="{Binding ScorePercent, StringFormat=P0}"
                                                Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Лучший результат"
                                                Binding="{Binding BestScorePercent, StringFormat=P0}"
                                                Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#007ACC"/>
                                        <Setter Property="FontWeight" Value="ExtraBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ═══ НИЖНЯЯ ПАНЕЛЬ С КНОПКАМИ ═══ -->
            <Border Grid.Row="5"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,18,18"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                    <Button Content="💾 Сохранить изменения"
                            Command="{Binding UpdateCommand}"
                            Background="#33AA33"
                            Style="{StaticResource ActionButtonStyle}"
                            Width="228"
                            Margin="0,0,10,0"
                            ToolTip="Сохранить изменения логина, email и роли пользователя" Height="47"/>

                    <Button Content="🗑 Удалить пользователя"
                            Command="{Binding DeleteCommand}"
                            Background="#CC0000"
                            Style="{StaticResource ActionButtonStyle}"
                            Width="246"
                            ToolTip="Невозможно удалить администратора или самого себя." Height="45"/>

                    <!-- Подсказка для Преподавателя -->
                    <TextBlock Text="📋 Режим просмотра — редактирование доступно только Администратору"
                               Foreground="#888888"
                               FontSize="13"
                               FontStyle="Italic"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTeacherMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>

<Window x:Class="Computer_networks.MainWindow"
        KeyDown="MainWindow_KeyDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Computer_networks.Views"
        xmlns:utilities="clr-namespace:Computer_networks.Utilities"
        xmlns:attached="clr-namespace:Computer_networks.AttachedProperties"
        mc:Ignorable="d"
        Title="Электронный учебник: Информационные технологии" 
        Height="800" 
        Width="1300"
        MinHeight="500" 
        MinWidth="800"
        Icon="/images/i (3).ico"  
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowState="Maximized">

    <Window.Resources>
        <utilities:BoolToSelectedBackground x:Key="BoolToSelectedBackground"/>
        <utilities:PercentToActualWidth x:Key="PercentToActualWidth"/>
        <utilities:UnlockedToBackground x:Key="UnlockedToBackground"/>
        <utilities:UnlockedToBorder x:Key="UnlockedToBorder"/>
        <utilities:UnlockedToTitleColor x:Key="UnlockedToTitleColor"/>
        <utilities:UnlockedToProgressColor x:Key="UnlockedToProgressColor"/>
        <utilities:PercentToWidth x:Key="PercentToWidth"/>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="Foreground" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- Стиль для кнопок тулбара -->
        <Style TargetType="Button" x:Key="ToolbarButtonStyle" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="Foreground" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок внутри контента -->
        <Style TargetType="Button" x:Key="ContentButtonStyle">
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005C99"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Главный Border с закруглением -->
    <Border CornerRadius="20" 
            Background="#F8F9F9"
            BorderBrush="#007ACC"
            BorderThickness="2"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Шапка окна (перетаскивание) -->
            <Border Grid.Row="0" 
                    Background="#007ACC" 
                    MouseLeftButtonDown="DragWindow"
                    CornerRadius="18,18,0,0"
                    Padding="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="📚" 
                                   FontSize="24" 
                                   Foreground="White" 
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="ЭЛЕКТРОННЫЙ УЧЕБНИК" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- #15 ИСПРАВЛЕНО: Добавлена кнопка сворачивания окна -->
                        <Button Content="🗕"
                                Click="MinimizeButton_Click"
                                Background="Transparent"
                                Foreground="White"
                                FontSize="20"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Width="50"
                                Height="50"/>
                        <Button Content="🗖"
                                Click="MaximizeButton_Click"
                                Background="Transparent"
                                Foreground="White"
                                FontSize="20"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Width="50"
                                Height="50"/>
                        <Button Content="✕"
                                Click="CloseButton_Click"
                                Background="Transparent"
                                Foreground="White"
                                FontSize="20"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Width="50"
                                Height="50"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Панель навигации -->
            <Border Grid.Row="1" 
                    Background="White"
                    BorderThickness="0"
                    Margin="0"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Верхняя панель инструментов -->
                    <StackPanel Grid.Row="0" 
                                Orientation="Horizontal" 
                                Margin="0,0,0,15"
                                HorizontalAlignment="Center">

                        <Button x:Name="GlossaryButton"
                                Content="📚 Словарь"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="0,0,5,0"
                                Click="ShowGlossary_Click"/>

                        <Button x:Name="HelpButton"
                                Content="❓ Справка (F1)"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="5,0,5,0"
                                Click="ShowHelp_Click"/>

                        <Button x:Name="LeaderboardButton"
                                Content="🏆 Лидеры"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="5,0,5,0"
                                Click="LeaderboardButton_Click"/>

                        <!-- Кнопка профиля (имя пользователя) -->
                        <Button x:Name="RegisterButton"
                                Content="👤 Регистрация/Вход"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="5,0,0,0"
                                Click="RegisterButton_Click"/>

                        <!-- Кнопка выхода — видна только когда вошли -->
                        <Button x:Name="LogoutButton"
                                Content="🚪"
                                ToolTip="Выйти из системы"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="2,0,5,0"
                                Visibility="Collapsed"
                                Click="LogoutButton_Click"/>



                        <!-- Выпадающий список курсов -->
                        <ComboBox x:Name="CourseSelector"
                                  Style="{StaticResource ToolbarComboBoxStyle}"
                                  Width="180"
                                  Height="30"
                                  Margin="10,0"
                                  VerticalAlignment="Center"
                                  DisplayMemberPath="CourseName"
                                  SelectedValuePath="CourseID"
                                  SelectionChanged="CourseSelector_SelectionChanged"/>

                        <!-- Поле поиска -->
                        <Border Background="White"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Margin="10,0,0,0"
                                Width="250">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="🔍" 
                                           FontSize="14" 
                                           Foreground="#999999"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="1"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="5,5,5,5"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Left"
                                         attached:PlaceholderTextBehavior.Placeholder="Поиск по темам..."
                                         TextChanged="SearchBox_TextChanged"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Плашка-приветствие (показывается при входе) -->
                    <Border x:Name="WelcomeBanner"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            CornerRadius="8"
                            Margin="0,0,0,10"
                            Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="WelcomeBannerIcon"
                                       Grid.Column="0"
                                       Text="👑"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="WelcomeBannerTitle"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF"/>
                                <TextBlock x:Name="WelcomeBannerSubtitle"
                                           FontSize="12"
                                           Foreground="#FFFFFF"
                                           Opacity="0.88"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="✕"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Opacity="0.7"
                                    Click="WelcomeBannerClose_Click"/>
                        </Grid>
                    </Border>

                    <!-- Вкладки -->
                    <TabControl Grid.Row="2" 
                                x:Name="MainTabControl" 
                                SelectionChanged="MainTabControl_SelectionChanged" 
                                BorderThickness="0"
                                Background="Transparent"
                                VirtualizingStackPanel.IsVirtualizing="True"
                                VirtualizingStackPanel.VirtualizationMode="Recycling">

                        <!-- Учебник -->
                        <TabItem Header="📖 Учебник" IsSelected="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="218*"/>
                                    <ColumnDefinition Width="723*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        BorderBrush="#CCCCCC" 
                                        BorderThickness="1" 
                                        Background="White" 
                                        Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Содержание" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Margin="0,0,0,10" 
                                                   Foreground="#007ACC"/>
                                        <TreeView x:Name="TableOfContentsTree"
                                                  SelectedItemChanged="TableOfContentsTree_SelectedItemChanged"
                                                  BorderThickness="0"
                                                  Background="White"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling"/>
                                    </StackPanel>
                                </Border>

                                <GridSplitter Grid.Column="1" 
                                              HorizontalAlignment="Center" 
                                              Width="5" 
                                              Background="Transparent"/>

                                <Grid Grid.Column="2" Margin="0" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>
                                    <GridSplitter Grid.Column="1" HorizontalAlignment="Left" Width="5" Background="Transparent"/>

                                    <!-- Левая колонка: контент темы -->
                                    <Border Grid.Column="0" 
            Background="White"
            BorderBrush="#CCCCCC"
            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Панель инструментов темы -->
                                            <Border Grid.Row="0" 
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,0,0,1"
                    Padding="10">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="PrevTopicButton" 
                            Content="⬅ Предыдущая" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="0,0,5,0" 
                            Click="NavigateTopic_Click"/>
                                                    <Button x:Name="NextTopicButton" 
                            Content="Следующая ➡" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="5,0,5,0" 
                            Click="NavigateTopic_Click"/>
                                                    <Button x:Name="BookmarkButton" 
                            Content="🔖 Закладка" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="5,0,5,0" 
                            Click="BookmarkButton_Click"/>
                                                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                                        <Button x:Name="IncreaseFontSizeButton" 
                                Content="A+" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Margin="0,0,2,0"
                                ToolTip="Увеличить размер шрифта" 
                                Click="IncreaseFontSizeButton_Click"/>
                                                        <Button x:Name="DecreaseFontSizeButton" 
                                Content="A-" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTip="Уменьшить размер шрифта" 
                                Click="DecreaseFontSizeButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Контент темы -->
                                            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          Padding="20"
                          Background="White">
                                                <ContentControl x:Name="MainContentHost" 
                                HorizontalAlignment="Stretch"/>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <!-- Правая колонка: ресурсы (файлы и ссылки) -->
                                    <Border Grid.Column="1" 
            Background="#F8F9FA"
            BorderBrush="#CCCCCC"
            BorderThickness="1,1,1,1"
            Padding="10">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- Заголовок -->
                                                <TextBlock Text="📎 Ресурсы темы" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#007ACC"
                           Margin="0,0,0,10"/>

                                                <!-- Секция файлов -->
                                                <TextBlock Text="Файлы" 
                           FontWeight="SemiBold"
                           Margin="0,5,0,5"/>
                                                <ItemsControl x:Name="TopicAttachmentsList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="White"
                                    CornerRadius="5"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    Padding="8"
                                    Margin="0,2,0,2"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Attachment_MouseLeftButtonUp">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Icon}" 
                                               FontSize="18" 
                                               Margin="0,0,8,0"/>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding FileName}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                                                        <TextBlock Text="{Binding SizeText}" 
                                                   FontSize="10" 
                                                   Foreground="#888"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Секция ссылок -->
                                                <TextBlock Text="Ссылки" 
                           FontWeight="SemiBold"
                           Margin="0,10,0,5"/>
                                                <ItemsControl x:Name="TopicLinksList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="White"
                                    CornerRadius="5"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    Padding="8"
                                    Margin="0,2,0,2"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Link_MouseLeftButtonUp">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" 
                                               Text="🔗" 
                                               FontSize="16" 
                                               Margin="0,0,8,0"/>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#007ACC"
                                                   TextWrapping="Wrap"/>
                                                                        <TextBlock Text="{Binding Domain}" 
                                                   FontSize="10" 
                                                   Foreground="#888"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Сообщение если нет ресурсов -->
                                                <TextBlock x:Name="NoResourcesText" 
                           Text="Нет прикреплённых ресурсов"
                           FontSize="12"
                           Foreground="#AAA"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- Тестирование -->
                        <TabItem Header="📝 Тестирование" x:Name="TestingTabItem">
                            <TabItem.Resources>

                                <!-- Карточка — белый блок с тенью, как в остальных вкладках -->
                                <Style x:Key="CardStyle" TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <!-- Строка теста в списке -->
                                <Style x:Key="TestListBoxItemStyle" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="#007ACC"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="12,10">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#F0F7FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#E8F0FE"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <!-- Бейдж с номером вопроса -->
                                <Style x:Key="QuestionNumberStyle" TargetType="Border">
                                    <Setter Property="Background" Value="#F0F7FF"/>
                                    <Setter Property="BorderBrush" Value="#007ACC"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="CornerRadius" Value="6"/>
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                </Style>

                                <!-- Блок с текстом вопроса -->
                                <Style x:Key="QuestionTextStyle" TargetType="Border">
                                    <Setter Property="Background" Value="#F8F9F9"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="20"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TabItem.Resources>

                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- ═══ ЛЕВАЯ ПАНЕЛЬ — список тестов ═══ -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource CardStyle}"
                                        Padding="15">
                                    <Grid x:Name="TestSelectionPanel">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Заголовок -->
                                        <Border Grid.Row="0"
                                                Background="#007ACC"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📝"
                                                           FontSize="16"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Доступные тесты"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Список тестов -->
                                        <ListBox x:Name="TestSelectionListBox"
                                                 Grid.Row="1"
                                                 SelectionChanged="TestSelectionListBox_SelectionChanged"
                                                 BorderBrush="#E0E0E0"
                                                 BorderThickness="1"
                                                 Background="#F8F9F9"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ItemContainerStyle="{StaticResource TestListBoxItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#2C3E50"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding QuestionCount, StringFormat={}{0} вопросов}"
                                                                   FontSize="11"
                                                                   Foreground="#888888"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- Кнопка старта -->
                                        <Button x:Name="StartTestButton"
                                                Grid.Row="2"
                                                Content="🚀 Начать выбранный тест"
                                                Style="{StaticResource ContentButtonStyle}"
                                                Background="#007ACC"
                                                Height="42"
                                                Margin="0,12,0,0"
                                                IsEnabled="False"
                                                Click="StartTestButton_Click"/>

                                        <!-- Статус -->
                                        <Border Grid.Row="3"
        Background="#F0F7FF"
        BorderBrush="#CCCCCC"
        BorderThickness="1"
        CornerRadius="6"
        Padding="10"
        Margin="0,8,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                   Text="💡 "
                   FontSize="12"
                   Foreground="#007ACC"
                   VerticalAlignment="Center"
                   Margin="0,0,5,0"/>

                                                <TextBlock Grid.Column="1"
                   x:Name="SelectedTestStatusText"
                   Text="Выберите тест для начала"
                   Foreground="#555555"
                   FontSize="12"
                   TextWrapping="Wrap"
                   TextAlignment="Left"
                   VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ═══ ПРАВАЯ ПАНЕЛЬ — вопросы и результаты ═══ -->
                                <Border Grid.Column="1"
                                        Style="{StaticResource CardStyle}"
                                        Margin="15,0,0,0">
                                    <Grid>

                                        <!-- Панель вопросов (видна во время теста) -->
                                        <Grid x:Name="QuestionDisplayPanel" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Синяя шапка вопроса (как тулбар в Учебнике) -->
                                            <Border Grid.Row="0"
                                                    Background="#007ACC"
                                                    CornerRadius="7,7,0,0"
                                                    Padding="20,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="❓"
                                                                   FontSize="16"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="QuestionNumberText"
                                                                   Text="Вопрос 1 из 10"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button x:Name="ExitTestButton"
                                                                Content="✕ Завершить"
                                                                Style="{StaticResource DeleteButtonStyle}"
                                                                Padding="14,6"
                                                                Click="ExitTestButton_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Текст вопроса -->
                                            <Border Grid.Row="1"
                                                    Style="{StaticResource QuestionTextStyle}"
                                                    Margin="20,20,20,0">
                                                <TextBlock x:Name="QuestionText"
                                                           Text="Здесь будет текст вопроса"
                                                           FontSize="16"
                                                           TextWrapping="Wrap"
                                                           Foreground="#333333"
                                                           LineHeight="24"/>
                                            </Border>

                                            <!-- Подзаголовок вариантов -->
                                            <TextBlock Grid.Row="2"
                                                       Text="Выберите ответ:"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#007ACC"
                                                       Margin="20,15,20,8"/>

                                            <!-- Варианты ответов -->
                                            <Border Grid.Row="3"
                                                    Background="#F8F9F9"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Margin="20,0,20,0">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Padding="15">
                                                    <StackPanel x:Name="AnswersPanel"/>
                                                </ScrollViewer>
                                            </Border>

                                            <!-- Нижняя панель с кнопкой -->
                                            <Border Grid.Row="4"
                                                    Background="#F0F0F0"
                                                    BorderBrush="#CCCCCC"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="20,12">
                                                <Button x:Name="NextQuestionButton"
                                                        Content="➡ Ответить и продолжить"
                                                        Style="{StaticResource ContentButtonStyle}"
                                                        Padding="25,10"
                                                        HorizontalAlignment="Right"
                                                        IsEnabled="False"
                                                        Click="NextQuestionButton_Click"/>
                                            </Border>
                                        </Grid>

                                        <!-- Панель результатов -->
                                        <StackPanel x:Name="TestResultPanel"
                                                    Visibility="Collapsed"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="40">

                                            <!-- Иконка -->
                                            <Border Background="#007ACC"
                                                    Width="90" Height="90"
                                                    CornerRadius="45"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="🎉"
                                                           FontSize="44"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <TextBlock Text="Тест завершён!"
                                                       FontSize="26"
                                                       FontWeight="Bold"
                                                       Foreground="#007ACC"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,18,0,6"/>

                                            <TextBlock Text="Вы справились. Вот ваш результат:"
                                                       FontSize="14"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,20"/>

                                            <!-- Результат -->
                                            <Border Background="#F0F7FF"
                                                    BorderBrush="#007ACC"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="40,20"
                                                    HorizontalAlignment="Center">
                                                <StackPanel>
                                                    <TextBlock Text="Ваш результат:"
                                                               FontSize="13"
                                                               Foreground="#666666"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="FinalScoreText"
                                                               FontSize="36"
                                                               FontWeight="ExtraBold"
                                                               Foreground="#007ACC"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Content="🔄 Пройти тест заново"
                                                    Click="StartTestButton_Click"
                                                    Style="{StaticResource ContentButtonStyle}"
                                                    Background="#007ACC"
                                                    Padding="30,12"
                                                    Margin="0,25,0,0"
                                                    HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Приветствие (по умолчанию) -->
                                        <StackPanel x:Name="WelcomePanel"
                                                    Visibility="Visible"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="40">


                                            <TextBlock Text="📝"
                                                            Foreground="#007ACC"
                                                           FontSize="72"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>


                                            <TextBlock Text="Проверьте свои знания"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="#007ACC"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,20,0,8"/>

                                            <TextBlock Text="Выберите тест из списка слева и нажмите «Начать»"
                                                       FontSize="18"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Margin="0,0,0,25"/>

                                            <!-- Советы (как в Учебнике) -->
                                            <Border Background="#F0F7FF"
                                                    BorderBrush="#CCCCCC"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="20">
                                                <StackPanel>
                                                    <TextBlock Text="✨ Советы:"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="#007ACC"
                                                               Margin="0,0,0,8"/>
                                                    <TextBlock Text="• Сначала изучите тему в учебнике"
                                                               FontSize="14"
                                                               Foreground="#555555"
                                                               Margin="0,3"/>
                                                    <TextBlock Text="• Отвечайте внимательно — ответ нельзя изменить"
                                                               FontSize="14"
                                                               Foreground="#555555"
                                                               Margin="0,3"/>
                                                    <TextBlock Text="• Результат сохраняется в вашем прогрессе"
                                                               FontSize="14"
                                                               Foreground="#555555"
                                                               Margin="0,3"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="🧪 Лабораторные" x:Name="LabsTabItem">
                            <TabItem.Resources>
                                <!-- Карточка — единый стиль с вкладкой Тестирование -->
                                <Style x:Key="CardStyle" TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <!-- Строка списка лабораторных — как TestListBoxItemStyle -->
                                <Style x:Key="LabListBoxItemStyle" TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="#007ACC"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="12,10">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#F0F7FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#E8F0FE"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabItem.Resources>

                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- ═══ ШАПКА — как в Тестировании ═══ -->
                                <Border Grid.Row="0" Grid.ColumnSpan="2"
                                        Background="#007ACC"
                                        CornerRadius="7"
                                        Padding="20,12"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="🧪"
                                                       FontSize="20"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Лабораторные работы"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                                <TextBlock x:Name="SelectedLabStatusText"
                                                           Text="Выберите лабораторную работу из списка"
                                                           FontSize="12"
                                                           Foreground="White"
                                                           Opacity="0.85"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="OpenLabAssignmentButton"
                                                    Content="📂 Открыть задание"
                                                    Style="{StaticResource ContentButtonStyle}"
                                                    Background="White"
                                                    Foreground="#007ACC"
                                                    Margin="0,0,8,0"
                                                    Padding="14,7"
                                                    Click="OpenLabAssignmentButton_Click"/>
                                            <Button x:Name="UploadLabReportButton"
                                                    Content="📤 Загрузить отчёт"
                                                    Style="{StaticResource ContentButtonStyle}"
                                                    Background="#005C99"
                                                    Padding="14,7"
                                                    Click="UploadLabReportButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ═══ ЛЕВАЯ ПАНЕЛЬ — список лаб ═══ -->
                                <Border Grid.Row="1" Grid.Column="0"
                                        Style="{StaticResource CardStyle}"
                                        Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Синий подзаголовок — как в Тестировании -->
                                        <Border Grid.Row="0"
                                                Background="#007ACC"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🧪"
                                                           FontSize="14"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Список лабораторных"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Список лабораторных -->
                                        <ListBox x:Name="LabsListBox"
                                                 Grid.Row="1"
                                                 BorderBrush="#E0E0E0"
                                                 BorderThickness="1"
                                                 Background="#F8F9F9"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ItemContainerStyle="{StaticResource LabListBoxItemStyle}"
                                                 SelectionChanged="LabsListBox_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#2C3E50"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Deadline, StringFormat=Срок: {0:dd.MM.yyyy}, TargetNullValue=Срок: не задан}"
                                                                   FontSize="11"
                                                                   Foreground="#888888"
                                                                   Margin="0,2,0,0"/>
                                                        <TextBlock Text="{Binding FileName, StringFormat=Файл: {0}, TargetNullValue=Файл задания: не загружен}"
                                                                   FontSize="11"
                                                                   Foreground="#888888"
                                                                   Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- ═══ ПРАВАЯ ПАНЕЛЬ — детали и загрузки ═══ -->
                                <Border Grid.Row="1" Grid.Column="1"
                                        Style="{StaticResource CardStyle}"
                                        Margin="15,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Синяя шапка выбранной лабы — как шапка вопроса в тестировании -->
                                        <Border Grid.Row="0"
                                                Background="#007ACC"
                                                CornerRadius="7,7,0,0"
                                                Padding="20,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="📋"
                                                               FontSize="16"
                                                               Foreground="White"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock x:Name="SelectedLabTitleText"
                                                                   Text="Лабораторная не выбрана"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                        <TextBlock x:Name="SelectedLabMetaText"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   Opacity="0.85"
                                                                   Margin="0,2,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Две колонки: мои загрузки + сдачи студентов -->
                                        <Grid Grid.Row="1" Margin="15,12,15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Мои загрузки -->
                                            <Border Grid.Column="0"
                                                    Background="#F8F9FA"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12"
                                                    Margin="0,0,6,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="📁"
                                                                   FontSize="14"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Text="Мои загрузки по курсу"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#2C3E50"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ListBox x:Name="MyReportsListBox"
                                                             Grid.Row="1"
                                                             BorderBrush="#E0E0E0"
                                                             BorderThickness="1"
                                                             Background="White"
                                                             ItemContainerStyle="{StaticResource LabListBoxItemStyle}">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,2">
                                                                    <TextBlock Text="{Binding LabTitle}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" Foreground="#2C3E50"/>
                                                                    <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding UploadedAt, StringFormat=Загружено: {0:dd.MM.yyyy HH:mm}}" FontSize="11" Foreground="#999"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </Border>

                                            <!-- Сдачи студентов (только для преп/админ) -->
                                            <Border x:Name="TeacherReportsPanel"
                                                    Grid.Column="1"
                                                    Background="#F8F9FA"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12"
                                                    Margin="6,0,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="👥"
                                                                   FontSize="14"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Text="Сдачи студентов"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#2C3E50"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ListBox x:Name="LabSubmissionsListBox"
                                                             Grid.Row="1"
                                                             BorderBrush="#E0E0E0"
                                                             BorderThickness="1"
                                                             Background="White"
                                                             ItemContainerStyle="{StaticResource LabListBoxItemStyle}">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,2">
                                                                    <TextBlock Text="{Binding Username, StringFormat=Студент: {0}}" FontWeight="SemiBold" FontSize="12" Foreground="#2C3E50"/>
                                                                    <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding UploadedAt, StringFormat=Сдано: {0:dd.MM.yyyy HH:mm}}" FontSize="11" Foreground="#999"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <!-- Панель управления (препод/админ) — нижняя, как в Тестировании -->
                                        <Border x:Name="LabAdminPanel"
                                                Grid.Row="2"
                                                Background="#F0F7FF"
                                                BorderBrush="#BFD8F5"
                                                BorderThickness="1"
                                                CornerRadius="0,0,7,7"
                                                Padding="20,12"
                                                Margin="0,10,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Заголовок панели с подсказкой -->
                                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="⚙️"
                                                                   FontSize="14"
                                                                   Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Управление лабораторными"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#007ACC"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="💡 Выберите лабу в списке слева — поля заполнятся для редактирования"
                                                               FontSize="11"
                                                               Foreground="#888"
                                                               VerticalAlignment="Center"
                                                               FontStyle="Italic"/>
                                                </Grid>
                                                <Grid Grid.Row="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- Строка 0: выбор курса (для преподавателя) -->
                                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="📚 Курс:"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="#007ACC"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"/>
                                                        <ComboBox x:Name="LabCourseSelector"
                                                                  Grid.Column="1"
                                                                  Height="34"
                                                                  DisplayMemberPath="CourseName"
                                                                  SelectedValuePath="CourseID"
                                                                  VerticalContentAlignment="Center"
                                                                  ToolTip="Выберите курс, в который добавить лабораторную"
                                                                  SelectionChanged="LabCourseSelector_SelectionChanged"
                                                                  BorderBrush="#007ACC"
                                                                  BorderThickness="1"/>
                                                    </Grid>
                                                    <!-- Строка 1: название + дата -->
                                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="180"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="LabTitleTextBox"
                                                                 Grid.Column="0"
                                                                 Height="34"
                                                                 Margin="0,0,8,0"
                                                                 VerticalContentAlignment="Center"
                                                                 attached:PlaceholderTextBehavior.Placeholder="Название лабораторной работы"
                                                                 ToolTip="Название лабораторной работы"/>
                                                        <DatePicker x:Name="LabDeadlineDatePicker"
                                                                    Grid.Column="1"
                                                                    Height="34"
                                                                    VerticalContentAlignment="Center"
                                                                    ToolTip="Срок сдачи"/>
                                                    </Grid>
                                                    <!-- Строка 2: описание + кнопки -->
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="LabDescriptionTextBox"
                                                                 Grid.Column="0"
                                                                 Height="34"
                                                                 Margin="0,0,8,0"
                                                                 VerticalContentAlignment="Center"
                                                                 attached:PlaceholderTextBehavior.Placeholder="Описание (необязательно)"
                                                                 ToolTip="Описание лабораторной работы (необязательно)"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <Button x:Name="AddLabButton"
                                                                    Content="➕ Добавить"
                                                                    Style="{StaticResource ContentButtonStyle}"
                                                                    Padding="14,6"
                                                                    Margin="0,0,6,0"
                                                                    ToolTip="Создать новую лабораторную с введёнными данными"
                                                                    Click="AddLabButton_Click"/>
                                                            <Button x:Name="EditLabButton"
                                                                    Content="✏️ Сохранить"
                                                                    Style="{StaticResource ContentButtonStyle}"
                                                                    Background="#28A745"
                                                                    Padding="14,6"
                                                                    Margin="0,0,6,0"
                                                                    IsEnabled="False"
                                                                    ToolTip="Сохранить изменения выбранной лабораторной"
                                                                    Click="EditLabButton_Click"/>
                                                            <Button x:Name="DeleteLabButton"
                                                                    Content="🗑️ Удалить"
                                                                    Style="{StaticResource DeleteButtonStyle}"
                                                                    Padding="14,6"
                                                                    Margin="0,0,6,0"
                                                                    IsEnabled="False"
                                                                    ToolTip="Удалить выбранную лабораторную и все отчёты по ней"
                                                                    Click="DeleteLabButton_Click"/>
                                                            <Button x:Name="UploadLabAssignmentFileButton"
                                                                    Content="📎 Файл задания"
                                                                    Style="{StaticResource ContentButtonStyle}"
                                                                    Background="#F0F7FF"
                                                                    Foreground="#007ACC"
                                                                    Padding="14,6"
                                                                    ToolTip="Загрузить файл задания для выбранной лабораторной"
                                                                    Click="UploadLabAssignmentFileButton_Click"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ═══ ПОДСКАЗКА СНИЗУ ═══ -->
                                <Border Grid.Row="2" Grid.ColumnSpan="2"
                                        Margin="0,12,0,0"
                                        Background="#F0F7FF"
                                        BorderBrush="#BFD8F5"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="💡 "
                                                   FontSize="12"
                                                   Foreground="#007ACC"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Студент видит задание и загружает отчёт. Преподаватель и администратор управляют лабораторными и контролируют сдачи."
                                                   Foreground="#345"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <!-- Прогресс -->
                        <TabItem Header="📊 Прогресс" x:Name="ProgressTabItem">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Мой прогресс, закладки и административные настройки" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                                <TabControl Grid.Row="1" Margin="0" BorderThickness="0">
                                    <!-- 🔖 Закладки -->
                                    <TabItem Header="🔖 Закладки" x:Name="BookmarksSubTab">
                                        <TabItem.Resources>
                                            <Style x:Key="CardStyle" TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Margin" Value="0,0,0,10"/>
                                                <Setter Property="Padding" Value="15"/>
                                            </Style>

                                            <Style TargetType="ListBox">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Margin" Value="10"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                                                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                                                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                                                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                                            </Style>

                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                                <Setter Property="Padding" Value="5,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8F9F9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#E8F0FE"/>
                                                        <Setter Property="BorderBrush" Value="#007ACC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TabItem.Resources>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Заголовок -->
                                            <Border Grid.Row="0" 
                Margin="10,10,10,0" 
                Background="#F0F7FF" 
                CornerRadius="8" 
                Padding="15" 
                BorderBrush="#007ACC" 
                BorderThickness="1">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="🔖" FontSize="24" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Ваши закладки" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#007ACC"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- ListBox с прокруткой -->
                                            <ListBox Grid.Row="1"
                 x:Name="BookmarksListView" 
                 Margin="10" 
                 HorizontalContentAlignment="Stretch" 
                 BorderBrush="#E0E0E0" 
                 BorderThickness="1"
                 SelectionChanged="BookmarksListView_SelectionChanged"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#F0F0F0" 
                            BorderThickness="0,0,0,1" 
                            Padding="15">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Название темы с иконкой -->
                                                                <StackPanel Grid.Column="0" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center">
                                                                    <Border Background="#007ACC"
                                        Width="32" Height="32"
                                        CornerRadius="5"
                                        Margin="0,0,10,0">
                                                                        <TextBlock Text="📌" 
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding TopicTitle}" 
                                           FontWeight="ExtraBold" 
                                           FontSize="16" 
                                           Foreground="#2C3E50" 
                                           TextWrapping="Wrap"/>
                                                                </StackPanel>

                                                                <!-- Дата -->
                                                                <TextBlock Grid.Column="1" 
                                       Text="{Binding DateAdded, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                       Foreground="#666666"
                                       FontSize="13"
                                       Margin="10,0,20,0"
                                       VerticalAlignment="Center"/>

                                                                <!-- Кнопка удаления -->
                                                                <Button Grid.Column="2"
                                    Content="🗑️"
                                    CommandParameter="{Binding}"
                                    Click="RemoveBookmarkButton_Click"
                                    Background="Transparent"
                                    Foreground="#FF4444"
                                    FontSize="16"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Width="30"
                                    Height="30"
                                    ToolTip="Удалить из закладок"
                                    VerticalAlignment="Center">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Foreground" Value="#CC0000"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </TabItem>
                                    <!-- 📊 Статистика -->
                                    <TabItem Header="📊 Статистика" x:Name="StatisticsTabItem" GotFocus="StatisticsTabItem_GotFocus">
                                        <TabItem.Resources>
                                            <Style TargetType="ListBox">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Margin" Value="10"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>

                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                                <Setter Property="Padding" Value="5,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8F9F9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#E8F0FE"/>
                                                        <Setter Property="BorderBrush" Value="#007ACC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>

                                            <Style x:Key="CardStyle" TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </TabItem.Resources>

                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <!-- Заголовок статистики -->
                                                <Border Margin="10,10,10,0" 
                    Background="#F0F7FF" 
                    CornerRadius="8" 
                    Padding="15" 
                    BorderBrush="#007ACC" 
                    BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="📊" FontSize="24" Margin="0,0,10,0"/>
                                                        <TextBlock Text="Ваша статистика обучения" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#007ACC"/>
                                                    </StackPanel>
                                                </Border>

                                                <ItemsControl x:Name="StatisticsListBox" Margin="10">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="15">
                                                                <StackPanel>
                                                                    <!-- Название темы с иконкой -->
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                        <Border Background="#007ACC"
                                            Width="30" Height="30"
                                            CornerRadius="5"
                                            Margin="0,0,10,0">
                                                                            <TextBlock Text="📌" 
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding TopicTitle}" 
                                               FontWeight="ExtraBold" 
                                               FontSize="16" 
                                               Foreground="#2C3E50" 
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                                                    </StackPanel>

                                                                    <!-- Статистика в виде прогресс-бара (если есть попытки) -->
                                                                    <Border Background="#F5F5F5"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <TextBlock Grid.Column="0" 
                                                   Text="Общий прогресс:" 
                                                   FontSize="12" 
                                                   Foreground="#666666"
                                                   Margin="0,0,10,0"/>

                                                                            <Grid Grid.Column="1">
                                                                                <Border Background="#E0E0E0"
                                                    Height="8"
                                                    CornerRadius="4"/>
                                                                                <Border Background="#007ACC"
                                                    Height="8"
                                                    CornerRadius="4"
                                                    HorizontalAlignment="Left">
                                                                                    <Border.Width>
                                                                                        <MultiBinding Converter="{StaticResource PercentToActualWidth}">
                                                                                            <Binding Path="BestScore"/>
                                                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                                                        </MultiBinding>
                                                                                    </Border.Width>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Grid>
                                                                    </Border>

                                                                    <!-- Три показателя в красивых карточках -->
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Количество попыток -->
                                                                        <Border Grid.Column="0" 
                                            Background="#F0F0F0"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,0,5,0">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                <TextBlock Text="🔄" FontSize="16" Margin="0,0,5,0"/>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="Попытки" 
                                                           FontSize="10" 
                                                           Foreground="#666666"
                                                           HorizontalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding Attempts, StringFormat={}{0}}" 
                                                           FontWeight="Bold"
                                                           Foreground="#555555"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"/>
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Border>

                                                                        <!-- Лучший результат -->
                                                                        <Border Grid.Column="1" 
                                            Background="#E3F2FD"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="5,0,5,0">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                <TextBlock Text="🏆" FontSize="16" Margin="0,0,5,0"/>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="Лучший" 
                                                           FontSize="10" 
                                                           Foreground="#007ACC"
                                                           HorizontalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding BestScore, StringFormat={}{0:F0}%}" 
                                                           FontWeight="Bold"
                                                           Foreground="#007ACC"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"/>
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Border>

                                                                        <!-- Средний результат -->
                                                                        <Border Grid.Column="2" 
                                            Background="#E8F5E9"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="5,0,0,0">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                <TextBlock Text="📊" FontSize="16" Margin="0,0,5,0"/>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="Средний" 
                                                           FontSize="10" 
                                                           Foreground="#28A745"
                                                           HorizontalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding AvgScore, StringFormat={}{0:F0}%}" 
                                                           FontWeight="Bold"
                                                           Foreground="#28A745"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"/>
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Grid>

                                                                    <!-- Дата последнего прохождения (если есть) -->
                                                                    <TextBlock Text="Нет прохождений" 
                                                                    FontSize="11"
                                                                    Foreground="#999999"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="0,10,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <!-- 🏆 Достижения -->
                                    <TabItem Header="🏆 Достижения" x:Name="AchievementsTabItem" GotFocus="AchievementsTabItem_GotFocus">
                                        <ListBox x:Name="AchievementsListBox" 
                                                 Margin="0" 
                                                 BorderThickness="0"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 HorizontalContentAlignment="Stretch"
                                                 Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding IsUnlocked, Converter={StaticResource UnlockedToBackground}}"
                                                            CornerRadius="0"
                                                            Padding="15,12"
                                                            BorderBrush="{Binding IsUnlocked, Converter={StaticResource UnlockedToBorder}}"
                                                            BorderThickness="0,0,0,1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Иконка -->
                                                            <Image Grid.Column="0" 
                                                                   Source="{Binding IconPath}" 
                                                                   Width="48" 
                                                                   Height="48" 
                                                                   Margin="0,0,20,0"
                                                                   VerticalAlignment="Center"/>

                                                            <!-- Название + описание + прогресс -->
                                                            <StackPanel Grid.Column="1" 
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}" 
                                                                           FontWeight="Bold" 
                                                                           FontSize="16"
                                                                           Foreground="{Binding IsUnlocked, Converter={StaticResource UnlockedToTitleColor}}"/>

                                                                <TextBlock Text="{Binding Description}" 
                                                                           FontSize="13"
                                                                           Foreground="#666666"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,2,0,2"/>

                                                                <!-- ПРОГРЕСС-БАР -->
                                                                <Grid Margin="0,5,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <!-- Фоновая полоса -->
                                                                    <Border Grid.Column="0" 
                                                                            Background="#E0E0E0"
                                                                            Height="10"
                                                                            CornerRadius="5"
                                                                            Margin="0,0,15,0"/>

                                                                    <!-- #16 ИСПРАВЛЕНО: Анимация заполнения прогресс-бара -->
                                                                    <Border x:Name="ProgressFill"
                                                                            Grid.Column="0" 
                                                                            Background="{Binding IsUnlocked, Converter={StaticResource UnlockedToProgressColor}}"
                                                                            Height="10"
                                                                            CornerRadius="5"
                                                                            HorizontalAlignment="Left"
                                                                            RenderTransformOrigin="0,0.5">
                                                                        <Border.RenderTransform>
                                                                            <ScaleTransform x:Name="ProgressScaleTransform" ScaleX="1"/>
                                                                        </Border.RenderTransform>
                                                                        <Border.Triggers>
                                                                            <EventTrigger RoutedEvent="Loaded">
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation
                                                                                            Storyboard.TargetName="ProgressScaleTransform"
                                                                                            Storyboard.TargetProperty="ScaleX"
                                                                                            From="0" To="1"
                                                                                            Duration="0:0:0.7"
                                                                                            EasingFunction="{x:Null}"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger>
                                                                        </Border.Triggers>
                                                                        <Border.Width>
                                                                            <MultiBinding Converter="{StaticResource PercentToActualWidth}">
                                                                                <Binding Path="ProgressPercent"/>
                                                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                                            </MultiBinding>
                                                                        </Border.Width>
                                                                    </Border>

                                                                    <!-- Текст прогресса -->
                                                                    <TextBlock Grid.Column="1" 
                                                                               Text="{Binding ProgressText}" 
                                                                               FontSize="12"
                                                                               Foreground="#555555"
                                                                               FontWeight="SemiBold"/>
                                                                </Grid>
                                                            </StackPanel>

                                                            <!-- Статус + XP -->
                                                            <StackPanel Grid.Column="2" 
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"
                                                                        Margin="20,0,0,0">
                                                                <TextBlock Text="{Binding XP, StringFormat='+{0} XP'}" 
                                                                           FontSize="14"
                                                                           FontWeight="Bold"
                                                                           Foreground="#28A745"
                                                                           HorizontalAlignment="Right"/>

                                                                <TextBlock Text="{Binding UnlockedDate, StringFormat='dd.MM.yyyy', TargetNullValue='🔒 Не получено'}" 
                                                                           FontSize="11"
                                                                           Foreground="#888888"
                                                                           HorizontalAlignment="Right"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </TabItem>

                                    <!-- ⚙️ Администрирование -->
                                    <TabItem Header="⚙️ Администрирование"	
                                             x:Name="AdminSettingsTabItem"	
                                             Visibility="Collapsed"
                                             GotFocus="AdminSettingsTabItem_GotFocus">
                                        <ContentControl x:Name="AdminContent" />
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- Статус бар -->
            <Border Grid.Row="2" 
                    Background="#DDDDDD"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,1,0,0"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" 
                               Text="Статус: Готов к работе." 
                               Foreground="#555555"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" 
                               Grid.Column="1"
                               Text="Версия 1.0 | C# WPF | SQL Server" 
                               Foreground="#555555"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>